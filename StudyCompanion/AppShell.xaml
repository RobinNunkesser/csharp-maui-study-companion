<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudyCompanion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StudyCompanion"
    xmlns:localization="clr-namespace:StudyCompanion.Resources.Strings"
    Shell.FlyoutBehavior="Flyout">

    <FlyoutItem Title="{x:Static localization:AppResources.Mensa}" Icon="mensa.svg">
        <ShellContent ContentTemplate="{DataTemplate local:MensaPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.Quiz}" Icon="quiz.svg">
        <ShellContent ContentTemplate="{DataTemplate local:QuizPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.Courses}" Icon="courses.svg">
        <ShellContent ContentTemplate="{DataTemplate local:CoursesPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.Profs}" Icon="profs.svg">
        <ShellContent ContentTemplate="{DataTemplate local:ProfsPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.Settings}" Icon="settings.svg">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

</Shell>

